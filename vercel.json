{
  "version": 2,
  "builds": [
    { "src": "api/auth.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/auth.js" },
    { "src": "/mobile.css", "dest": "/public/mobile.css" },
    { "src": "/favicon.ico", "dest": "/public/favicon.ico" },
    { "src": "/dashboard", "dest": "/api/auth.js" },
    { "src": "/client", "dest": "/api/auth.js" },
    { "src": "/reports", "dest": "/api/auth.js" },
    { "src": "/docs-report", "dest": "/api/auth.js" },
    { "src": "/audit-logs", "dest": "/api/auth.js" },
    { "src": "/trucks", "dest": "/api/auth.js" }, { "src": "/ttsd-checklist", "dest": "/api/auth.js" }, { "src": "/tutorial", "dest": "/api/auth.js" },
    { "src": "/", "dest": "/api/auth.js" },
    { "src": "/(.*)", "dest": "/public/" }
  ]
}


